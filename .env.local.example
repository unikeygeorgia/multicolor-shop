# Multicolor — environment variables
# Copy to .env.local and fill in from your multicolor-shop Supabase project
# (Project Settings → API). NEXT_PUBLIC_* values are safe to expose client-side.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (never commit the real value). Used for admin writes / seeding.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
