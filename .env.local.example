# Multicolor — environment variables
# Copy to .env.local and fill in from your multicolor-shop Supabase project
# (Project Settings → API). NEXT_PUBLIC_* values are safe to expose client-side.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only (never commit the real value). Required for /api/orders to create
# accounts + write user-linked orders. Get it from Supabase → Settings → API →
# "service_role" secret. Add to .env.local for dev AND to Vercel env vars.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
